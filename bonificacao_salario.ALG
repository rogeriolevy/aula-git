Algoritmo "Salario de Bonificaçăo"

Var
salario, novoSalario: Real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
novoSalario <- (20/100)
escreval("Digite o valor do seu sálario: ")
leia(salario)
novoSalario <- salario + (salario * novoSalario)
escreval("O novo valor do salário com aumento de 20% é: ", novoSalario)

Fimalgoritmo